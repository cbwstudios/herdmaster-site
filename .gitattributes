# Normalize line endings to LF in the repo and working tree, so the
# inline-screens build script (which detects EOL) is deterministic across
# machines and doesn't ping-pong the generated CSS block on Windows.
* text=auto eol=lf

# Binary assets: never touch line endings.
*.webp binary
*.png binary
*.jpg binary
*.jpeg binary
*.svg text eol=lf
*.woff2 binary
*.ico binary
*.pdf binary
